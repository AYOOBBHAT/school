# Backend Server Environment Variables
# Copy this file to .env and fill in your actual values
# IMPORTANT: .env files are gitignored - never commit real credentials!
#
# NOTE: EXPO_PUBLIC_API_URL belongs in the MOBILE app (.env in apps/mobile), not here.
# The mobile app uses it to call this backend. Set it to this backend's public URL
# after you deploy (e.g. https://your-app.up.railway.app).

# Supabase Configuration (REQUIRED)
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Server Configuration
PORT=4000
HOST=0.0.0.0
NODE_ENV=production

# Monthly fee rows (monthly_fee_components) — generation job
# When true, server schedules a daily job at 02:00 to ensure current month exists for all active students.
ENABLE_MONTHLY_FEE_GENERATION_CRON=false
# Optional IANA timezone for that schedule (e.g. Asia/Kolkata). Omit to use server local time.
# CRON_TIMEZONE=
# One catch-up run at startup for the current month (optional; can be slow on large schools).
FEE_GENERATION_ON_STARTUP=false
# Before GET /clerk-fees/analytics/unpaid: ensure end-of-window month exists (regenerate from fee structure).
# Set to false to disable on-demand writes during analytics requests.
FEE_GENERATION_ON_ANALYTICS=true
# Max students per analytics request to scan/generate (missing end-month rows only).
FEE_GENERATION_ANALYTICS_MAX_STUDENTS=400

# Redis (Upstash) — REQUIRED for forgot-password OTP + rate limits; also used for optional caching
# Get these from: Upstash Dashboard
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

RESEND_FROM_EMAIL=noreply@
RESEND_API_KEY=your_resend_api_key_here
